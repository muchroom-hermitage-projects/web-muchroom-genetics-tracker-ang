{
  "name": "mycology-genetics-tracker",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\" && eslint \"src/**/*.ts\" --fix",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.3.12",
    "@angular/core": "^17.3.12",
    "@angular/forms": "^17.3.12",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "@angular/router": "^17.3.12",
    "@types/uuid": "^9.0.0",
    "cytoscape": "^3.25.0",
    "cytoscape-dagre": "^2.5.0",
    "eslint-config-prettier": "^10.1.8",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "uuid": "^9.0.0",
    "zone.js": "0.14.10"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "1.9.4",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular-eslint/builder": "17.5.3",
    "@angular-eslint/eslint-plugin": "17.5.3",
    "@angular-eslint/eslint-plugin-template": "17.5.3",
    "@angular-eslint/schematics": "17.5.3",
    "@angular-eslint/template-parser": "17.5.3",
    "@angular/cli": "~17.3.17",
    "@angular/compiler-cli": "^17.3.12",
    "@types/cytoscape": "^3.19.0",
    "@types/cytoscape-dagre": "^2.3.4",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^2.7.1",
    "typescript": "~5.4.5",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "zone.js": "0.14.10",
    "typescript": "~5.4.5"
  },
  "lint-staged": {
    "*.{ts,html,scss,css,json}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}
