{
  "name": "mycology-genetics-tracker",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint",
    "lint:staged": "npx lint-staged --debug",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\" && eslint \"src/**/*.ts\" --fix",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.19",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.19",
    "@angular/compiler": "^19.2.19",
    "@angular/core": "^19.2.19",
    "@angular/forms": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.19",
    "@angular/platform-browser-dynamic": "^19.2.19",
    "@angular/router": "^19.2.19",
    "@types/uuid": "^9.0.0",
    "cytoscape": "^3.25.0",
    "cytoscape-context-menus": "^4.2.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-navigator": "2.0.1",
    "eslint-config-prettier": "^10.1.8",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "uuid": "^9.0.0",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "1.9.4",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^19.2.22",
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/schematics": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/cli": "~19.2.22",
    "@angular/compiler-cli": "^19.2.19",
    "@playwright/test": "^1.58.2",
    "@types/cytoscape": "^3.19.0",
    "@types/cytoscape-context-menus": "^4.1.5",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/cytoscape-navigator": "^2.0.4",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@typescript-eslint/types": "^8.46.0",
    "@typescript-eslint/utils": "^8.46.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^2.7.1",
    "typescript": "5.8.3",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "zone.js": "0.15.1",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{html,scss,css,json}": [
      "prettier --write"
    ]
  }
}
