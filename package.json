{
  "name": "mycology-genetics-tracker",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "lint": "ng lint",
    "lint:staged": "./node_modules/.bin/lint-staged --debug",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\" && eslint \"src/**/*.ts\" --fix",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@types/uuid": "^9.0.0",
    "cytoscape": "^3.25.0",
    "cytoscape-context-menus": "^4.2.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-navigator": "2.0.1",
    "eslint-config-prettier": "^10.1.8",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "uuid": "^9.0.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "3.0.0-alpha.8",
    "@analogjs/vitest-angular": "3.0.0-alpha.8",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.2",
    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@playwright/test": "^1.58.2",
    "@types/cytoscape": "^3.19.0",
    "@types/cytoscape-context-menus": "^4.1.5",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/cytoscape-navigator": "^2.0.4",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@typescript-eslint/types": "^8.46.0",
    "@typescript-eslint/utils": "^8.33.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^2.7.1",
    "sass": "^1.98.0",
    "typescript": "5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{html,scss,css,json}": [
      "prettier --write"
    ]
  }
}
